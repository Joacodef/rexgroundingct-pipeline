# ==============================================================================
# ReXGroundingCT Challenge - Environment Variable Configuration Template
# ==============================================================================
# Copy this file to '.env' at the repository root and adjust the absolute paths
# according to your server/local development system configuration.
#
# Note: The '.env' file is excluded from git tracking via '.gitignore'.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Path Overrides (Optional — Leave blank to use ./data defaults via config.py)
# ------------------------------------------------------------------------------
# Set custom paths below if running on external scratch storage (e.g. SLURM /scratch)
# If left blank or omitted, config.py automatically defaults paths relative to project root.

# Base project root override (Optional)
BASE_DIR=

# Raw datasets (Specify external cluster paths if stored outside project root)
IMG_RAW_DIR=
SEG_RAW_DIR=

# Preprocessed datasets, predictions, and dataset index
DATA_PREP_DIR=
DATA_PRED_DIR=
DATASET_JSON=

# Pretrained model weights & fine-tuning checkpoints
MODEL_DIR=
CHECKPOINTS_DIR=

# ------------------------------------------------------------------------------
# 2. Volatile Cache Paths (Optional / Recommended)
# ------------------------------------------------------------------------------
# High-speed volatile cache directory (e.g. ramdisk /tmp or node-local scratch)
# Used to accelerate I/O intensive preprocessed volumetric loads during runtime
TMP_PREP_DIR=/tmp/your_username/rexgroundingct_preprocessed

# ------------------------------------------------------------------------------
# 3. GPU Hardware Visibility & Devices
# ------------------------------------------------------------------------------
# Default hardware device for MONAI/PyTorch tensor operations
DEFAULT_DEVICE=cuda:0

# NOTE: Do NOT set CUDA_VISIBLE_DEVICES in your active '.env' file on SLURM-managed
# clusters. SLURM manages GPU isolation dynamically and sets this environment
# variable automatically for each job. Setting it here will overwrite the scheduler's
# allocations and can lead to runtime conflicts.

# For LOCAL (non-SLURM) executions, you can uncomment and set this to isolate GPUs:
# CUDA_VISIBLE_DEVICES=0

# ------------------------------------------------------------------------------
# 4. Cloud Telemetry & Dataset Configuration
# ------------------------------------------------------------------------------

# Weights & Biases (W&B) Logging
# Used to track the training loss, dice coefficients, and system metrics
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=rexgroundingct-challenge
# Set to 'offline' if running on a cluster node without external internet access
WANDB_MODE=online

# Hugging Face Configuration
# Required to download the CT-RATE validation/test datasets programmatically
HF_TOKEN=your_hf_access_token_here
# Optional: Set a custom path if you don't want Hugging Face downloading to ~/.cache
# HF_HOME=/absolute/path/to/your/custom/hf_cache
